{
  "manifest_version": 3,
  "name": "AlphaScroll - Auto Shorts",
  "version": "1.0",
  "description": "Automatically scrolls YouTube Shorts with a built-in timer.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/shorts/*"],
      "js": ["content.js"]
    }
  ]
}
